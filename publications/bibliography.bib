@article{yoris_delving_2024,
	title = {Delving into the relationship between regular physical exercise and cardiac interoception in two cross-sectional studies},
	volume = {198},
	copyright = {CC0 1.0 Universal Public Domain Dedication},
	issn = {0028-3932},
	doi = {10.1016/j.neuropsychologia.2024.108867},
	abstract = {Cardiac interoception, the ability to sense and process cardiac afferent
signals, has been shown to improve after a single session of acute
physical exercise. However, it remains unclear whether repetitive
engagement in physical exercise over time leads to long-term changes in
cardiac interoceptive accuracy. It is also unknown whether those changes
affect the neural activity associated with the processing of afferent
cardiac signals, assessed by the heart-evoked potential (HEP). In this
study, we aimed to investigate this hypothesis through two cross-sectional
studies, categorizing participants as active or inactive based on physical
fitness (Study I; N = 45) or self-reported physical activity levels (Study
II; N = 60). Interoception was assessed at rest using the HEP (Studies I
and II), the Heartbeat Counting task (Study II), and the Rubber Hand
Illusion (RHI) (Study II). Study I showed strong evidence of better
cardiovascular fitness in the active group than in the inactive group as
well as robust between-group differences in electrocardiogram (ECG)
recordings. Study 2 replicated the clear differences in ECG as a function
of regular physical activity. Those results were expected due to clear
differences in physical activity habits. In contrast, our analysis
revealed no robust differences between groups across cardiac interoception
tasks and the RHI, although the direct relevance of these measures to
interoception remains under investigation. In sum, our results do not
provide convincing evidence to support a strong version of the notion that
regular physical exercise is associated with an enhanced in cardiac
interoception.},
	journal = {Neuropsychologia},
	author = {Yoris, Adrián E and Cira, Luis F and Luque-Casado, Antonio and Salvotti, Caterina and Tajadura-Jiménez, Ana and Avancini, Chiara and Zarza-Rebollo, Juan Antonio and Sanabria, Daniel and Perakakis, Pandelis},
	month = jun,
	year = {2024},
	note = {note: "[Open Access](https://doi.org/10.31234/osf.io/42gcm)"},
	keywords = {Cardiac signal, Heartbeat-evoked potential, Interoception, Physical fitness, Regular physical activity, Rubber hand illusion},
	pages = {108867},
	file = {Yoris et al. 2024 - Delving into the relationship between regular physical exercise and cardiac interoception in two cross-sectional studies.pdf:/Users/pandelis/Library/CloudStorage/GoogleDrive-perakakis@gmail.com/My Drive/Zotero_library/Yoris et al. 2024 - Delving into the relationship between regular physical exercise and cardiac interoception in two cross-sectional studies.pdf:application/pdf},
}

@article{bailon_covidaffect_2020,
	title = {{CoVidAffect}, real-time monitoring of mood variations following the {COVID}-19 outbreak in {Spain}},
	volume = {7},
	copyright = {CC0 1.0 Universal Public Domain Dedication},
	issn = {2052-4463},
	url = {http://dx.doi.org/10.1038/s41597-020-00700-1},
	doi = {10.1038/s41597-020-00700-1},
	abstract = {The COVID-19 outbreak and the ensuing confinement measures are expected to
bear a significant psychological impact on the affected populations. To
date, all available studies designed to investigate the psychological
effects of this unprecedented global crisis are based on cross-sectional
surveys that do not capture emotional variations over time. Here, we
present the data from CoVidAffect, a nationwide citizen science project
aimed to provide longitudinal data of mood changes following the COVID-19
outbreak in the spanish territory. Spain is among the most affected
countries by the pandemic, with one of the most restrictive and prolonged
lockdowns worldwide. The project also collected a baseline of demographic
and socioeconomic data. These data can be further analyzed to quantify
emotional responses to specific measures and policies, and to understand
the effect of context variables on psychological resilience. Importantly,
to our knowledge this is the first dataset that offers the opportunity to
study the behavior of emotion dynamics in a prolonged lockdown situation.},
	number = {1},
	journal = {Sci Data},
	author = {Bailon, Carlos and Goicoechea, Carmen and Banos, Oresti and Damas, Miguel and Pomares, Hector and Correa, Angel and Sanabria, Daniel and Perakakis, Pandelis},
	month = oct,
	year = {2020},
	pages = {365},
	file = {Bailon et al. 2020 - CoVidAffect, real-time monitoring of mood variations following the COVID-19 outbreak in Spain.pdf:/Users/pandelis/Library/CloudStorage/GoogleDrive-perakakis@gmail.com/My Drive/Zotero_library/Bailon et al. 2020 - CoVidAffect, real-time monitoring of mood variations following the COVID-19 outbreak in Spain.pdf:application/pdf},
}

