@article{perakakis_technical_2019,
	title = {A technical note on the precise timing of behavioral events in economic experiments},
	volume = {21},
	copyright = {CC0 1.0 Universal Public Domain Dedication},
	issn = {2214-6350},
	url = {http://www.sciencedirect.com/science/article/pii/S2214635018301163},
	doi = {10.1016/j.jbef.2018.08.002},
	abstract = {The increasing use of physiological recordings in experimental economics
requires a precise timing of interesting events, such as the presentation
of a set of choices, the decision-making moment and the reception of
feedback through the display of a decision outcome. In this note we
provide a simple, accurate and inexpensive solution based on the use of
external photo-sensors that detect changes in light intensity on the
participants’ screens occurring in synchrony with experimental events.
This system ensures an accurate communication between standard programs
broadly used to run behavioral economic experiments, such as z-Tree, and
eye-tracking devices or biosignal acquisition systems recording
physiological variables, such as skin conductance, heart rate and
electroencephalogram. An example is briefly discussed, offering specific
guidelines for the application of this methodology in economic contexts
with strategic interaction.},
	journal = {Journal of Behavioral and Experimental Finance},
	author = {Perakakis, Pandelis and Guinot-Saporta, José and Jaber-Lopez, Tarek and García-Gallego, Aurora and Georgantzis, Nikolaos},
	month = mar,
	year = {2019},
	keywords = {Behavioral economics, Eye tracking, Psychophysiology},
	pages = {10--14},
	file = {Perakakis et al. 2019 - A technical note on the precise timing of behavioral events in economic experiments:/Users/pandelis/Zotero/storage/GC8H4L7Z/Perakakis et al. 2019 - A technical note on the precise timing of behavioral events in economic experiments.pdf:application/pdf},
}

