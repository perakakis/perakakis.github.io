
@article{viedmadeljesus_sketching_2011,
	title = {Sketching the first 45 years of the journal {Psychophysiology} (1964–2008): {A} co‐word‐based analysis},
	volume = {48},
	copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#vor},
	issn = {0048-5772, 1469-8986},
	shorttitle = {Sketching the first 45 years of the journal \textit{{Psychophysiology}} (1964–2008)},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/j.1469-8986.2011.01171.x},
	doi = {10.1111/j.1469-8986.2011.01171.x},
	abstract = {Abstract
            
              This article presents a keyword‐based bibliometric study of the thematic evolution of the journal Psychophysiology since its first publication in 1964 until 2008. Bibliometric maps showing the most relevant associations among the main topics treated by the journal are provided separately for the periods 1964–1978, 1979–1988, 1989–1998, and 1999–2008. These maps offer insight into the conceptual structure of psychophysiology as a research discipline and help to visualize the division of the field into several interconnected subfields. Bibliometric maps created by co‐word analysis can be used by both experts and novices to understand the current state of the art of a scientific field and to predict where future research could lead.},
	language = {en},
	number = {8},
	urldate = {2024-11-13},
	journal = {Psychophysiology},
	author = {Viedma‐Del‐Jesus, Maria Isabel and Perakakis, Pandelis and Muñoz, Miguel Ángel and López‐Herrera, Antonio Gabriel and Vila, Jaime},
	month = aug,
	year = {2011},
	pages = {1029--1036},
	file = {Viedma‐Del‐Jesus et al. - 2011 - Sketching the first 45 years of the journal Psychophysiology (1964–2008) A co‐word‐based ana.pdf:/Users/pandelis/Library/CloudStorage/GoogleDrive-perakakis@gmail.com/My Drive/Zotero_library/Viedma‐Del‐Jesus et al. - 2011 - Sketching the first 45 years of the journal Psychophysiology (1964–2008) A co‐word‐based ana.pdf:application/pdf},
}

@article{perakakis_kardia_2010,
	title = {{KARDIA}: {A} {Matlab} software for the analysis of cardiac interbeat intervals},
	volume = {98},
	copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},
	issn = {01692607},
	shorttitle = {{KARDIA}},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0169260709002867},
	doi = {10.1016/j.cmpb.2009.10.002},
	abstract = {This article presents KARDIA, a Matlab (MathWorks Inc., MA) software developed for the analysis of cardiac interbeat interval (IBI) data. Available functions are called through a graphical user interface and permit the study of phasic cardiac responses (PCRs) and the estimation of time and frequency domain heart rate variability (HRV) parameters. Scaling exponents of heartbeat ﬂuctuations are calculated with the detrended ﬂuctuation analysis (DFA) algorithm. Grand average and individual subject results can be exported to spreadsheets for further statistical analysis. KARDIA is distributed free of charge under the terms of GNU public license so that other users can modify the code and adjust the program’s performance according to their own scientiﬁc requirements.},
	language = {en},
	number = {1},
	urldate = {2024-11-13},
	journal = {Computer Methods and Programs in Biomedicine},
	author = {Perakakis, Pandelis and Joffily, Mateus and Taylor, Michael and Guerra, Pedro and Vila, Jaime},
	month = apr,
	year = {2010},
	pages = {83--89},
	file = {Perakakis et al. - 2010 - KARDIA A Matlab software for the analysis of cardiac interbeat intervals.pdf:/Users/pandelis/Library/CloudStorage/GoogleDrive-perakakis@gmail.com/My Drive/Zotero_library/Perakakis et al. - 2010 - KARDIA A Matlab software for the analysis of cardiac interbeat intervals.pdf:application/pdf},
}

